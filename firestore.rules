rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /contacts/{contactId} {
      // Allow public lead creation but validate shape and size
      allow create: if
        // Must contain exactly these fields
        request.resource.data.keys().hasAll(['name', 'email', 'phone', 'serviceType', 'message', 'createdAt'])
        && request.resource.data.keys().size() == 6

        // Field type checks
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.serviceType is string
        && request.resource.data.message is string
        && request.resource.data.createdAt is timestamp

        // Length / value constraints
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.phone.size() >= 10
        && request.resource.data.phone.size() <= 20
        && request.resource.data.serviceType in ['automotive', 'residential', 'commercial']
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 500;

      allow read, update, delete: if false;
    }

    // By default, deny all other reads and writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
